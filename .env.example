# Database
DATABASE_URL="sqlite:///./medecho.db"
DIRECT_URL=""

# OpenAI API (Required for transcription & fallback EMR)
OPENAI_API_KEY="your_openai_api_key_here"

# Anthropic API (Optional - for data augmentation/evaluation)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Sarvam AI (Optional - for high-quality Indian language transcription)
SARVAM_API_KEY="your_sarvam_api_key_here"

# HuggingFace (Optional - for fine-tuned Mistral model)
HF_API_TOKEN="your_huggingface_token_here"
HF_MISTRAL_MODEL="negi3961/mediscribe-mistral"

# ABDM (Optional - India Health Stack / ABHA ID integration)
ABDM_CLIENT_ID="your_abdm_client_id_here"
ABDM_CLIENT_SECRET="your_abdm_client_secret_here"
ABDM_BASE_URL="https://healthidsbx.abdm.gov.in/api"

# Frontend URL (for CORS and QR codes)
FRONTEND_URL="http://localhost:3000"

# QR Code Security (REQUIRED: 32+ char secret key)
QR_SECRET_KEY="replace_with_a_strong_secret_key_at_least_32_chars"
